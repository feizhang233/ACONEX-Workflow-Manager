# Application
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
# Optional explicit Fernet key (url-safe base64 32 bytes). If empty, derived from SECRET_KEY.
ENCRYPTION_KEY=
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:////app/data/aconex_manager.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_TIMEZONE=Europe/Belgrade
HOST=0.0.0.0
PORT=8000

# Optional tuning
ACONEX_PAGE_SIZE=250
ACONEX_REQUEST_TIMEOUT=120
ACONEX_MAX_RETRIES=5
